    {
        "id": "5dea03428b9e9609",
        "type": "function",
        "z": "f5b7bcbd12e35b10",
        "name": "chart_function",
        "func": "let payload = msg.payload;\n\nif (Buffer.isBuffer(payload)) {\n    payload = payload.toString();\n}\n\nif (typeof payload === \"string\") {\n    try {\n        payload = JSON.parse(payload);\n\n\n    } catch (e) {\n        node.warn(\"payload not legal JSON: \" + payload);\n        return null;\n    }\n}\n\nif (!payload) {\n    return null;\n}\n\n// 现在 imu_start 已经关闭，但保留兼容\nif (payload.type === \"imu_start\") {\n    node.status({ fill: \"blue\", shape: \"ring\", text: \"start\" });\n    return null;\n}\n\nif (payload.type === \"imu_end\") {\n    node.status({\n        fill: \"green\",\n        shape: \"dot\",\n        text: `done pairs=${payload.pairs ?? \"\"}`\n    });\n    return null;\n}\n\nif (payload.type !== \"imu\") {\n    return null;\n}\n\n// 新格式字段：i0 / i1\nif (\n    !payload.i0 || !payload.i1 ||\n    !payload.i0.a || !payload.i0.g ||\n    !payload.i1.a || !payload.i1.g\n) {\n    node.warn(\"missing i0/i1 acc or gyro fields\");\n    return null;\n}\n\nlet idx = payload.idx ?? 0;\n\n// 如果想每次新 batch 清空 chart\nlet imu0_acc = [];\nlet imu0_gyro = [];\nlet imu1_acc = [];\nlet imu1_gyro = [];\n\nif (idx === 0) {\n    imu0_acc.push({ payload: [] });\n    imu0_gyro.push({ payload: [] });\n    imu1_acc.push({ payload: [] });\n    imu1_gyro.push({ payload: [] });\n\n    node.status({\n        fill: \"blue\",\n        shape: \"ring\",\n        text: `batch total=${payload.total ?? \"\"}`\n    });\n}\n\nif (payload.idx % 5 !== 0) return null;\n// IMU0 加速度 Output 1\nimu0_acc.push(\n    { topic: \"Acc_X\", payload: payload.i0.a[0], timestamp: idx, idx },\n    { topic: \"Acc_Y\", payload: payload.i0.a[1], timestamp: idx, idx },\n    { topic: \"Acc_Z\", payload: payload.i0.a[2], timestamp: idx, idx }\n);\n\n// IMU0 陀螺仪 Output 2\nimu0_gyro.push(\n    { topic: \"Gyro_X\", payload: payload.i0.g[0], timestamp: idx, idx },\n    { topic: \"Gyro_Y\", payload: payload.i0.g[1], timestamp: idx, idx },\n    { topic: \"Gyro_Z\", payload: payload.i0.g[2], timestamp: idx, idx }\n);\n\n// IMU1 加速度 Output 3\nimu1_acc.push(\n    { topic: \"Acc_X\", payload: payload.i1.a[0], timestamp: idx, idx },\n    { topic: \"Acc_Y\", payload: payload.i1.a[1], timestamp: idx, idx },\n    { topic: \"Acc_Z\", payload: payload.i1.a[2], timestamp: idx, idx }\n);\n\n// IMU1 陀螺仪 Output 4\nimu1_gyro.push(\n    { topic: \"Gyro_X\", payload: payload.i1.g[0], timestamp: idx, idx },\n    { topic: \"Gyro_Y\", payload: payload.i1.g[1], timestamp: idx, idx },\n    { topic: \"Gyro_Z\", payload: payload.i1.g[2], timestamp: idx, idx }\n);\n\nreturn [imu0_acc, imu0_gyro, imu1_acc, imu1_gyro];\n",
