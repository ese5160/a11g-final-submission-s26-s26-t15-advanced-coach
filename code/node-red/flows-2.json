    {
        "id": "4e8822d066ba0be4",
        "type": "function",
        "z": "f5b7bcbd12e35b10",
        "name": "result_display",
        "func": "let payload = msg.payload;\n\n// 1. buffer → string\nif (Buffer.isBuffer(payload)) {\n    payload = payload.toString();\n}\n\n// 2. string → JSON\nif (typeof payload === \"string\") {\n    try {\n        payload = JSON.parse(payload);\n    } catch (e) {\n        node.warn(\"JSON parse failed: \" + payload);\n        return [null, null, null, null, null, null];\n    }\n}\n\n// 3. 检查格式\nif (!payload || payload.type !== \"inference_result\") {\n    node.warn(\"Not inference_result type\");\n    return [null, null, null, null, null, null];\n}\n\nlet r = payload.results;\n\n// 安全读取函数\nfunction fmt(label, prob) {\n    if (prob === undefined || prob === null) return `${label}`;\n    return `${label} (${prob.toFixed(3)})`;\n}\n\n// 6个输出\nlet msg_overall = { payload: `Overall: ${r.overall?.label ?? \"N/A\"}` };\n\nlet msg_start = { payload: `Start: ${fmt(r.start_action?.label ?? \"N/A\", r.start_action?.prob_good)}` };\n\nlet msg_finish = { payload: `Finish: ${fmt(r.finish_action?.label ?? \"N/A\", r.finish_action?.prob_good)}` };\n\nlet msg_cont = { payload: `Continuity: ${fmt(r.continuity?.label ?? \"N/A\", r.continuity?.prob_good)}` };\n\nlet msg_offset = { payload: `Offset: ${fmt(r.offset?.label ?? \"N/A\", r.offset?.prob_good)}` };\n\nlet msg_wrist = { payload: `Wrist: ${fmt(r.wrist_action?.label ?? \"N/A\", r.wrist_action?.prob_good)}` };\n\n// 返回6路\nreturn [\n    msg_overall,\n    msg_start,\n    msg_finish,\n    msg_cont,\n    msg_offset,\n    msg_wrist\n];",
        "outputs": 6,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
